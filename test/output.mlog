sensor cryo_level reactor1 @cryofluid
jump 11 lessThan cryo_level 12
control enabled reactor1 1 0 0 0
print "=== reactor1 STABLE ===
"
print "Coolant: "
print cryo_level
print " ед.
"
print "Status: OPERATIONAL"
jump 20 always 0 0
control enabled reactor1 0 0 0 0
print "!!! WARNING !!!
"
print "CRITICAL COOLING FAILURE!
"
print "Cryogenic level dropped to: "
print cryo_level
print "
REACTOR SHUTDOWN INITIATED!"
printflush message1
jump 0 always 0 0